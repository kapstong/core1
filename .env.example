DB_TYPE=mysql
DB_HOST=localhost
DB_NAME=core1
DB_USER=root
DB_PASSWORD=change_me
DB_CHARSET=utf8mb4

APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=change_me

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=change_me
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Core1

SESSION_LIFETIME=7200
SESSION_SECURE=false

CORS_ALLOWED_ORIGINS=http://localhost

CHATBOT_LLM_ENABLED=true
OPENAI_API_KEY=change_me
CHATBOT_LLM_BASE_URL=https://api.openai.com/v1
CHATBOT_LLM_PROVIDER=openai_compatible
CHATBOT_LLM_MODEL=gpt-4o-mini
CHATBOT_LLM_TEMPERATURE=0.35
CHATBOT_LLM_MAX_TOKENS=700
CHATBOT_LLM_TIMEOUT_SECONDS=35

ADMIN_AI_ENABLED=true
ADMIN_AI_API_KEY=change_me
ADMIN_AI_BASE_URL=https://api.openai.com/v1
ADMIN_AI_MODEL=gpt-4o
ADMIN_AI_TEMPERATURE=0.35
ADMIN_AI_MAX_TOKENS=700
ADMIN_AI_TIMEOUT_SECONDS=35
ADMIN_AI_ENABLE_EVALUATE=false
ADMIN_AI_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_AI_RATE_LIMIT_MAX_REQUESTS=48
ADMIN_AI_RATE_LIMIT_ACTION_MAX_REQUESTS=180
